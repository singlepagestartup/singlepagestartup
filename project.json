{
  "name": "@sps/source",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "targets": {
    "drafts:list": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/drafts/list.ts",
        "forwardAllArgs": true
      }
    },
    "drafts:dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/drafts/dev.ts",
        "forwardAllArgs": true
      }
    },
    "drafts:init": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/drafts/init.ts",
        "forwardAllArgs": true
      }
    },
    "drafts:validate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/drafts/validate-manifests.ts",
        "forwardAllArgs": true
      }
    },
    "drafts:ds:inventory": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/drafts/design-system/inventory.ts",
        "forwardAllArgs": true
      }
    },
    "drafts:ds:dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/drafts/design-system/dev.ts",
        "forwardAllArgs": true
      }
    },
    "drafts:ds:validate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/drafts/design-system/validate.ts",
        "forwardAllArgs": true
      }
    },
    "drafts:storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook dev -c apps/drafts/.storybook -p 4320 -h 127.0.0.1",
        "forwardAllArgs": true
      }
    },
    "drafts:storybook:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook build -c apps/drafts/.storybook -o dist/drafts/storybook",
        "forwardAllArgs": true
      }
    },
    "local-registry": {
      "executor": "@nx/js:verdaccio",
      "options": {
        "port": 4873,
        "location": "global",
        "config": ".verdaccio/config.yml",
        "storage": "local-registry/storage"
      }
    },
    "force-stop-registry": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "pkill -f verdaccio"
          }
        ]
      }
    }
  }
}
