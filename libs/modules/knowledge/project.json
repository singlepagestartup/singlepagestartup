{
  "name": "@sps/knowledge",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/modules/knowledge",
  "projectType": "library",
  "tags": [],
  "targets": {
    "eslint:lint": {},
    "jest:test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{projectRoot}/coverage"],
      "inputs": ["{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/knowledge/jest.config.ts",
        "passWithNoTests": false
      }
    },
    "jest:integration": {
      "executor": "@nx/jest:jest",
      "outputs": ["{projectRoot}/coverage"],
      "inputs": ["{projectRoot}"],
      "options": {
        "jestConfig": "libs/modules/knowledge/jest.integration.config.ts",
        "passWithNoTests": true
      }
    },
    "tsc:build": {},
    "index": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "envFile": "apps/api/.env",
        "command": "bun run libs/modules/knowledge/backend/app/api/src/lib/indexer/cli.ts"
      }
    },
    "repository-generate": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": false,
        "commands": [
          {
            "command": "nx run @sps/knowledge:models:repository-generate"
          },
          {
            "command": "nx run @sps/knowledge:relations:repository-generate"
          }
        ]
      }
    },
    "repository-migrate": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "parallel": false,
        "commands": [
          {
            "command": "nx run @sps/knowledge:models:repository-migrate"
          },
          {
            "command": "nx run @sps/knowledge:relations:repository-migrate"
          }
        ]
      }
    },
    "models:repository-generate": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": false,
        "commands": [
          {
            "command": "nx run @sps/knowledge:models:source:repository-generate"
