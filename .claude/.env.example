# Claude Project Configuration — Example
# Copy this file to .claude/.env and fill in the values.
# See .claude/README.md for setup instructions.
#
# GitHub login/project IDs are resolved dynamically at runtime.
# PROJECT_NODE_ID, STATUS_FIELD_ID, and status option UUIDs are resolved dynamically at runtime.

# Target repository for issue operations and thoughts/shared artifact namespaces.
# Format: owner/name, for example: flakecode/doctorgpt
#
# Leave empty when remote.origin.url points at the correct GitHub repository.
# Set this when:
# - the checkout has an upstream/default GitHub repo that differs from origin;
# - `gh repo view` resolves to the wrong repository;
# - automation runs outside a normal git checkout.
#
# Without the correct target repo, workflow commands can read/update the wrong
# GitHub issue, use the wrong Project item, post comments to the wrong repo, or
# write artifacts under the wrong thoughts/shared/<repo>/ directory.
TARGET_REPO=

# GitHub Project number (from: gh project list --me  OR  gh project list --owner ORG)
GITHUB_PROJECT_NUMBER=

# Who owns the GitHub Project — may differ from the target repository owner.
# Leave empty for the authenticated user's personal project, or set explicitly.
GITHUB_PROJECT_OWNER=

# "user" or "organization" — determines which GraphQL entity to query
# Default: "user". Set to "organization" if the project belongs to a GitHub org.
GITHUB_PROJECT_OWNER_TYPE=user

# SPS browser testing credentials.
# Used by browser-tester agents for authenticated localhost UI checks.
# Keep real values only in .claude/.env; never commit them.
API_RBAC_SUBJECT_IDENTITY_EMAIL=
API_RBAC_SUBJECT_IDENTITY_PASSWORD=
