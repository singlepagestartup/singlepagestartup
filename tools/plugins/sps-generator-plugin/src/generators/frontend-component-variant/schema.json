{
  "$schema": "https://json-schema.org/schema",
  "$id": "CreateFrontendComponentVariant",
  "title": "",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "description": "Action to perform",
      "x-prompt": {
        "message": "Create will create a new relation between two models. Remove will remove a relation between two models.",
        "type": "list",
        "default": "create",
        "items": [
          {
            "value": "create"
          },
          {
            "value": "remove"
          }
        ]
      }
    },
    "name": {
      "type": "string",
      "description": "",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name of variant would you like to use?"
    },
    "template": {
      "type": "string",
      "description": "",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name of variant would you like to use?"
    },
    "level": {
      "type": "string",
      "description": "Type of component",
      "x-prompt": {
        "message": "Which type of component would you like to generate?",
        "type": "list",
        "default": "singlepage",
        "items": [
          {
            "value": "startup"
          },
          {
            "value": "singlepage"
          }
        ]
      }
    },
    "type": {
      "type": "string",
      "description": "Model or Relation?",
      "x-prompt": {
        "message": "Which type of component would you like to generate?",
        "type": "list",
        "default": "model",
        "items": [
          {
            "value": "model"
          },
          {
            "value": "relation"
          }
        ]
      }
    },
    "entity": {
      "type": "string",
      "description": "Name of model (page) or relation (pages-to-layouts)",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use?"
    },
    "path": {
      "type": "string",
      "description": "Path to component",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Where would you like to create the component?"
    },
    "module": {
      "type": "string",
      "description": "Module",
      "x-prompt": {
        "message": "Select module for creating model",
        "type": "list",
        "default": "website-builder",
        "items": [
          { "value": "agent" },
          { "value": "analytic" },
          { "value": "billing" },
          { "value": "blog" },
          { "value": "broadcast" },
          { "value": "crm" },
          { "value": "ecommerce" },
          { "value": "file-storage" },
          { "value": "host" },
          { "value": "notification" },
          { "value": "rbac" },
          { "value": "social" },
          { "value": "startup" },
          { "value": "telegram" },
          { "value": "website-builder" }
        ]
      }
    },
    "left_model_is_external": {
      "type": "boolean",
      "description": "Whether the inferred left model is external"
    },
    "right_model_is_external": {
      "type": "boolean",
      "description": "Whether the inferred right model is external"
    },
    "left_model_name": {
      "type": "string",
      "description": "Optional override for relation left model name"
    },
    "left_module_name": {
      "type": "string",
      "description": "Optional override for relation left model module"
    },
    "right_model_name": {
      "type": "string",
      "description": "Optional override for relation right model name"
    },
    "right_module_name": {
      "type": "string",
      "description": "Optional override for relation right model module"
    }
  },
  "required": ["action", "name", "path", "level", "type", "entity", "module"]
}
