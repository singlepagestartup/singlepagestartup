{
  "$schema": "https://json-schema.org/schema",
  "$id": "CreateModel",
  "title": "",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use?"
    },
    "module": {
      "type": "string",
      "description": "Module",
      "x-prompt": {
        "message": "Select module for creating model",
        "type": "list",
        "default": "website-builder",
        "items": [
          { "value": "agent" },
          { "value": "analytic" },
          { "value": "billing" },
          { "value": "blog" },
          { "value": "broadcast" },
          { "value": "crm" },
          { "value": "ecommerce" },
          { "value": "file-storage" },
          { "value": "host" },
          { "value": "notification" },
          { "value": "rbac" },
          { "value": "social" },
          { "value": "startup" },
          { "value": "telegram" },
          { "value": "website-builder" }
        ]
      }
    },
    "action": {
      "type": "string",
      "description": "Action to perform",
      "x-prompt": {
        "message": "Create will create a new model. Remove will remove the model.",
        "type": "list",
        "default": "create",
        "items": [
          {
            "value": "create"
          },
          {
            "value": "remove"
          }
        ]
      }
    }
  },
  "required": ["action", "name", "module"]
}
