ungrouped:
  vars:
    ansible_ssh_common_args: "-o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/dev/null"
  hosts:
    # AWS Lightsail Ubuntu with SSH key authentication.
    "XX.XXX.XXX.XXX":
      ansible_user: ubuntu
      ansible_port: 22
      ansible_ssh_private_key_file: /absolute/path/to/LightsailDefaultKey.pem

    # Password authentication remains available for other providers.
    "server.example.com":
      ansible_user: root
      ansible_port: 22
      ansible_password: "password"
