version: "3.7"

services:
  {{ SERVICE_NAME }}:
    image: {{ DOCKER_HUB_URL }}/{{ DOCKER_HUB_SERVICE_REPOSITORY }}
    networks:
      - traefik_overlay
    env_file:
      - ./{{ SERVICE_NAME }}.env
    command: "sh -c './start.sh llm'"
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    deploy:
      update_config:
        order: start-first
      placement:
        constraints:
          - node.role == manager

  ollama:
    image: ollama/ollama:latest
    volumes:
      - /home/code/ollama_data:/root/.ollama
    networks:
      - traefik_overlay
    environment:
      OLLAMA_HOST: 0.0.0.0:11434
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    deploy:
      update_config:
        order: start-first
      placement:
        constraints:
          - node.role == manager

  ollama-init:
    image: ollama/ollama:latest
    volumes:
      - /home/code/ollama_data:/root/.ollama
      - /home/code/ollama-init.sh:/usr/local/bin/ollama-init.sh:ro
    networks:
      - traefik_overlay
    environment:
      OLLAMA_HOST: http://ollama:11434
      OLLAMA_MODEL_IDS: "{{ OLLAMA_MODEL_IDS | default('nomic-embed-text', true) }}"
    entrypoint: ["/bin/sh"]
    command: ["/usr/local/bin/ollama-init.sh"]
    deploy:
      replicas: 1
      restart_policy:
        condition: any
        delay: 5s
      placement:
        constraints:
          - node.role == manager

networks:
  traefik_overlay:
    external: true
