API_SERVICE_URL=http://api:4000
NEXT_PUBLIC_API_SERVICE_URL=https://{{ API_SERVICE_URL }}

MCP_SERVICE_HTTP_HOST=0.0.0.0
MCP_SERVICE_HTTP_PORT=3001
MCP_SERVICE_PUBLIC_BASE_URL=https://{{ SERVICE_URL }}
MCP_SERVICE_PUBLIC_URL=https://{{ SERVICE_URL }}/mcp
MCP_SERVICE_AUTH_REQUIRED=true
MCP_SERVICE_ALLOW_RBAC_SECRET_FALLBACK={{ MCP_SERVICE_ALLOW_RBAC_SECRET_FALLBACK | default('false', true) }}
{% if MCP_SERVICE_ALLOW_RBAC_SECRET_FALLBACK is defined and MCP_SERVICE_ALLOW_RBAC_SECRET_FALLBACK == 'true' and RBAC_SECRET_KEY is defined and RBAC_SECRET_KEY | length > 0 %}
RBAC_SECRET_KEY={{ RBAC_SECRET_KEY }}
{% endif %}
{% if MCP_SERVICE_ALLOWED_ORIGINS is defined and MCP_SERVICE_ALLOWED_ORIGINS | length > 0 %}
MCP_SERVICE_ALLOWED_ORIGINS={{ MCP_SERVICE_ALLOWED_ORIGINS }}
{% endif %}
MCP_SERVICE_INTERNAL_TOKEN_EXCHANGE_SECRET={{ MCP_SERVICE_INTERNAL_TOKEN_EXCHANGE_SECRET }}

RBAC_JWT_SECRET={{ RBAC_JWT_SECRET }}
{% if MCP_SERVICE_OAUTH_JWT_SECRET is defined and MCP_SERVICE_OAUTH_JWT_SECRET | length > 0 %}
MCP_SERVICE_OAUTH_JWT_SECRET={{ MCP_SERVICE_OAUTH_JWT_SECRET }}
{% else %}
MCP_SERVICE_OAUTH_JWT_SECRET={{ RBAC_JWT_SECRET }}
{% endif %}
MCP_SERVICE_OAUTH_STORE=redis
{% if MCP_SERVICE_OAUTH_AUTH_CODE_TTL_SECONDS is defined and MCP_SERVICE_OAUTH_AUTH_CODE_TTL_SECONDS | length > 0 %}
MCP_SERVICE_OAUTH_AUTH_CODE_TTL_SECONDS={{ MCP_SERVICE_OAUTH_AUTH_CODE_TTL_SECONDS }}
{% else %}
MCP_SERVICE_OAUTH_AUTH_CODE_TTL_SECONDS=300
{% endif %}
{% if MCP_SERVICE_OAUTH_ACCESS_TOKEN_TTL_SECONDS is defined and MCP_SERVICE_OAUTH_ACCESS_TOKEN_TTL_SECONDS | length > 0 %}
MCP_SERVICE_OAUTH_ACCESS_TOKEN_TTL_SECONDS={{ MCP_SERVICE_OAUTH_ACCESS_TOKEN_TTL_SECONDS }}
{% else %}
MCP_SERVICE_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
{% endif %}
{% if MCP_SERVICE_OAUTH_REFRESH_TOKEN_TTL_SECONDS is defined and MCP_SERVICE_OAUTH_REFRESH_TOKEN_TTL_SECONDS | length > 0 %}
MCP_SERVICE_OAUTH_REFRESH_TOKEN_TTL_SECONDS={{ MCP_SERVICE_OAUTH_REFRESH_TOKEN_TTL_SECONDS }}
{% else %}
MCP_SERVICE_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
{% endif %}

KV_PROVIDER=redis
KV_HOST=redis
KV_PORT={{ REDIS_PORT | default('6379', true) }}
{% if REDIS_PASSWORD is defined and REDIS_PASSWORD | length > 0 %}
KV_PASSWORD={{ REDIS_PASSWORD }}
{% endif %}
