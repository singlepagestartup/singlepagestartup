TELEGRAM_SERVICE_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX

TELEGRAM_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_TELEGRAM_SERVICE_URL=https://telegram.your-domain.com

# Required subscription channel for bot
TELEGRAM_SERVICE_REQUIRED_SUBSCRIPTION_CHANNEL_ID=-XXXXXXXXXXXXX
TELEGRAM_SERVICE_REQUIRED_SUBSCRIPTION_CHANNEL_NAME=channel_name
TELEGRAM_SERVICE_REQUIRED_SUBSCRIPTION_CHANNEL_LINK=https://t.me/+XXXXXXXXXXXXXXX

NEXT_PUBLIC_API_SERVICE_URL=https://api.your-domain.com

RBAC_SECRET_KEY=XXXXXXXXXXXXXXXXXXXX
RBAC_JWT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Required for Telegram voice-note transcription
OPEN_AI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional. Defaults to gpt-4o-transcribe when unset.
OPEN_AI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
