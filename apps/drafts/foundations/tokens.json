{
  "$schema": "https://singlepagestartup.local/schemas/drafts/tokens.schema.json",
  "name": "sps-drafts-default",
  "version": "0.1.0",
  "modes": {
    "light": {
      "color": {
        "background": "#eaf0f7",
        "foreground": "#111827",
        "surface": "#ffffff",
        "surfaceMuted": "#f4f7fb",
        "surfaceRaised": "#ffffff",
        "border": "#d6dfeb",
        "borderStrong": "#b9c6d7",
        "primary": "#111827",
        "primaryForeground": "#f9fafb",
        "secondary": "#2563eb",
        "secondaryForeground": "#ffffff",
        "accent": "#14b8a6",
        "accentForeground": "#042f2e",
        "muted": "#e8edf4",
        "mutedForeground": "#6b7280",
        "danger": "#dc2626"
      }
    },
    "dark": {
      "color": {
        "background": "#0f172a",
        "foreground": "#f8fafc",
        "surface": "#111827",
        "surfaceMuted": "#1f2937",
        "surfaceRaised": "#172033",
        "border": "#334155",
        "borderStrong": "#475569",
        "primary": "#f8fafc",
        "primaryForeground": "#111827",
        "secondary": "#60a5fa",
        "secondaryForeground": "#0f172a",
        "accent": "#2dd4bf",
        "accentForeground": "#042f2e",
        "muted": "#1e293b",
        "mutedForeground": "#cbd5e1",
        "danger": "#f87171"
      }
    }
  },
  "spacing": {
    "2xs": "0.25rem",
    "xs": "0.5rem",
    "sm": "0.75rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem",
    "3xl": "4rem",
    "4xl": "6rem"
  },
  "radius": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "full": "9999px"
  },
  "typography": {
    "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
    "body": {
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "eyebrow": {
      "fontSize": "0.8125rem",
      "lineHeight": "1.4",
      "fontWeight": "700"
    },
    "heading": {
      "fontSize": "clamp(2.25rem, 5vw, 4.75rem)",
      "lineHeight": "1.02",
      "fontWeight": "750"
    },
    "subheading": {
      "fontSize": "clamp(1.125rem, 2vw, 1.375rem)",
      "lineHeight": "1.5",
      "fontWeight": "400"
    }
  },
  "shadow": {
    "sm": "0 1px 2px rgb(15 23 42 / 0.08)",
    "md": "0 12px 30px rgb(15 23 42 / 0.10)",
    "lg": "0 24px 70px rgb(15 23 42 / 0.14)"
  }
}
