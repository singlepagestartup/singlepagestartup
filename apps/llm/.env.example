# HuggingFace token (required to download gated models)
HF_TOKEN=

# OpenAI API key (for transcription postprocessing — punctuation and error correction)
OPENAI_API_KEY=
OPEN_AI_API_KEY=

# Cloud providers exposed through the local gateway
ANTHROPIC_API_KEY=

# Optional comma-separated HuggingFace chat model ids to preload on startup.
# Keep empty on small local machines; models are lazy-loaded by default.
LLM_PRELOAD_MODEL_IDS=
LLM_MAX_LOADED_HF_MODELS=1

# Whisper model size: openai/whisper-tiny | openai/whisper-base | openai/whisper-small | openai/whisper-medium
WHISPER_MODEL=openai/whisper-small

# Device: cpu | cuda (Docker on Mac always uses cpu)
WHISPER_DEVICE=cpu

# Compute type: int8 (fastest on cpu) | float16 (for cuda)
WHISPER_COMPUTE_TYPE=int8

# Ollama embeddings service
OLLAMA_URL=http://localhost:11434
OLLAMA_PORT=11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Comma-separated Ollama models pulled by ollama-init.
# Keep the embedding model here plus local generation models used by Knowledge.
OLLAMA_MODELS=nomic-embed-text,qwen3:1.7b
